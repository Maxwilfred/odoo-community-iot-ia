<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_measurement_tree" model="ir.ui.view">
        <field name="name">iot.measurement.tree</field>
        <field name="model">iot.measurement</field>
        <field name="arch" type="xml">
            <tree>
                <field name="device_id"/>
                <field name="timestamp"/>
                <field name="value"/>
                <field name="unit"/>
                <field name="threshold_exceeded"/>
            </tree>
        </field>
    </record>

    <record id="view_iot_measurement_form" model="ir.ui.view">
        <field name="name">iot.measurement.form</field>
        <field name="model">iot.measurement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="device_id"/>
                        <field name="timestamp"/>
                        <field name="value"/>
                        <field name="unit"/>
                        <field name="threshold_exceeded"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_iot_measurement" model="ir.actions.act_window">
        <field name="name">Mesures IoT</field>
        <field name="res_model">iot.measurement</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>